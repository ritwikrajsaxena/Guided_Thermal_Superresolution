@torch.no_grad()
def validate(model, loader, device, use_ensemble=False):
    model.eval()
    psnrs, ssims = [], []
    for batch in loader:
        lr, hr, vis = batch[0], batch[1], batch[2]
        lr, hr, vis = lr.to(device), hr.to(device), vis.to(device)
        pred = self_ensemble(model, lr, vis) if use_ensemble else \
               model(lr, vis, training=False)
        pred = pred.clamp(0, 1)
        if pred.shape[2:] != hr.shape[2:]:
            pred = F.interpolate(pred, hr.shape[2:],
                                 mode="bilinear", align_corners=False)
        for i in range(pred.size(0)):
            p = pred[i, 0].cpu().numpy()
            h = hr[i, 0].cpu().numpy()
            psnrs.append(calc_psnr(h, p, data_range=1.0))
            ssims.append(calc_ssim(h, p, data_range=1.0))
    return float(np.mean(psnrs)), float(np.mean(ssims))


@torch.no_grad()
def bicubic_baseline(loader, scale, device):
    """Compute bicubic-only PSNR/SSIM for reference."""
    psnrs, ssims = [], []
    for batch in loader:
        lr, hr = batch[0].to(device), batch[1].to(device)
        bic = F.interpolate(lr, scale_factor=scale,
                            mode="bicubic", align_corners=False)
        if bic.shape[2:] != hr.shape[2:]:
            bic = F.interpolate(bic, hr.shape[2:],
                                mode="bilinear", align_corners=False)
        bic = bic.clamp(0, 1)
        for i in range(bic.size(0)):
            p = bic[i, 0].cpu().numpy()
            h = hr[i, 0].cpu().numpy()
            psnrs.append(calc_psnr(h, p, data_range=1.0))
            ssims.append(calc_ssim(h, p, data_range=1.0))
    return float(np.mean(psnrs)), float(np.mean(ssims))


