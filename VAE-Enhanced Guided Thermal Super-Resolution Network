class ConvVAEEncoder(nn.Module):
    """
    Lightweight convolutional encoder for feature-space VAE.
    Operates on nf-channel feature maps at LR resolution.
    """
    def __init__(self, in_ch, latent_dim=32):
        super().__init__()
        mid = in_ch
        self.encoder = nn.Sequential(
            nn.Conv2d(in_ch, mid, 3, 1, 1),
            nn.GroupNorm(8, mid),
            nn.LeakyReLU(0.2, True),
            nn.Conv2d(mid, mid, 3, 1, 1),
            nn.GroupNorm(8, mid),
            nn.LeakyReLU(0.2, True),
        )
        self.mu     = nn.Conv2d(mid, latent_dim, 1)
        self.logvar = nn.Conv2d(mid, latent_dim, 1)

        # Initialize logvar small → small initial variance → stable
        nn.init.constant_(self.logvar.weight, 0)
        nn.init.constant_(self.logvar.bias, -2.0)   # exp(-2) ≈ 0.135

    def forward(self, x):
        h = self.encoder(x)
        return self.mu(h), self.logvar(h)


class ConvVAEDecoder(nn.Module):
    """Lightweight convolutional decoder for feature-space VAE."""
    def __init__(self, latent_dim, out_ch):
        super().__init__()
        mid = out_ch
        self.decoder = nn.Sequential(
            nn.Conv2d(latent_dim, mid, 3, 1, 1),
            nn.GroupNorm(8, mid),
            nn.LeakyReLU(0.2, True),
            nn.Conv2d(mid, mid, 3, 1, 1),
            nn.GroupNorm(8, mid),
            nn.LeakyReLU(0.2, True),
            nn.Conv2d(mid, out_ch, 3, 1, 1),
        )

    def forward(self, z):
        return self.decoder(z)


class CrossModalVAE(nn.Module):
    """
    Cross-Modal VAE for thermal ↔ visible feature alignment.

    Why this works (vs broken code's VAE):
    ────────────────────────────────────────
    1. Operates in FEATURE space (not pixel space) → compact, stable
    2. Pretrained SEPARATELY before SR training → no training instability
    3. Lightweight (only ~2M extra params) → doesn't overwhelm SR model
    4. Gated fusion → model can learn to IGNORE VAE if unhelpful
    5. logvar clamped + initialized small → prevents variance explosion
    6. Separate encoders for each modality → proper alignment learning
    """
    def __init__(self, nf=64, latent_dim=32):
        super().__init__()
        self.latent_dim = latent_dim

        # Separate encoders
        self.enc_th  = ConvVAEEncoder(nf, latent_dim)
        self.enc_vis = ConvVAEEncoder(nf, latent_dim)

        # Shared decoder → reconstructs to nf channels
        self.decoder = ConvVAEDecoder(latent_dim, nf)

        # Learnable gated fusion in latent space
        self.fusion_gate = nn.Sequential(
            nn.Conv2d(latent_dim * 2, latent_dim, 1),
            nn.Sigmoid()
        )

        # Latent → feature projection (for conditioning the SR trunk)
        self.latent_proj = nn.Sequential(
            nn.Conv2d(latent_dim, nf, 1),
            nn.LeakyReLU(0.2, True),
            nn.Conv2d(nf, nf, 3, 1, 1),
        )

    @staticmethod
    def reparameterize(mu, logvar, training=True):
        if training:
            std = torch.exp(0.5 * logvar.clamp(-10, 2))
            return mu + torch.randn_like(std) * std
        return mu                                       # deterministic at test time

    @staticmethod
    def kl_divergence(mu, logvar):
        logvar = logvar.clamp(-10, 2)
        return -0.5 * torch.mean(1 + logvar - mu.pow(2) - logvar.exp())

    def forward(self, th_feat, vis_feat, training=True):
        """
        Args
        ────
        th_feat:  (B, nf, H, W)  thermal features from head
        vis_feat: (B, nf, H, W)  visible features (guide) at same resolution

        Returns
        ───────
        latent_feat:    (B, nf, H, W)  aligned features for trunk conditioning
        kl_loss:        scalar          KL divergence (training only)
        recon_loss:     scalar          feature reconstruction (training only)
        """
        mu_th,  logvar_th  = self.enc_th(th_feat)
        mu_vis, logvar_vis = self.enc_vis(vis_feat)

        z_th  = self.reparameterize(mu_th,  logvar_th,  training)
        z_vis = self.reparameterize(mu_vis, logvar_vis, training)

        # Gated fusion: learn how much to trust each modality
        gate   = self.fusion_gate(torch.cat([z_th, z_vis], 1))
        z_fused = gate * z_th + (1 - gate) * z_vis

        # Decode & project
        decoded     = self.decoder(z_fused)
        latent_feat = self.latent_proj(z_fused)

        if training:
            kl_loss     = self.kl_divergence(mu_th, logvar_th) + \
                          self.kl_divergence(mu_vis, logvar_vis)
            recon_loss  = F.l1_loss(decoded, th_feat)
            align_loss  = F.mse_loss(mu_th, mu_vis)
            return latent_feat, kl_loss, recon_loss + 0.1 * align_loss
        return latent_feat


