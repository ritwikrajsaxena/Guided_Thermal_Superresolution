def display_results(h8, h16, p8, s8, p16, s16):
    out = get_out_dir()

    print(f"\n{'='*70}")
    print("                  FINAL RESULTS SUMMARY")
    print(f"{'='*70}")
    print(f"  ×8   SE-PSNR = {p8:.2f} dB    SE-SSIM = {s8:.4f}")
    print(f"  ×16  SE-PSNR = {p16:.2f} dB    SE-SSIM = {s16:.4f}")
    print(f"{'='*70}")

    fig, axes = plt.subplots(1, 3, figsize=(16, 4))
    for hist, label in [(h8, "×8"), (h16, "×16")]:
        axes[0].plot(hist["epoch"], hist["loss"], label=label, alpha=0.7)
        eps = [e for e, v in zip(hist["epoch"], hist["psnr"]) if v is not None]
        pvs = [v for v in hist["psnr"] if v is not None]
        svs = [v for v in hist["ssim"] if v is not None]
        axes[1].plot(eps, pvs, "o-", label=label, markersize=2)
        axes[2].plot(eps, svs, "o-", label=label, markersize=2)

    axes[0].set(xlabel="Epoch", ylabel="Loss",      title="Training Loss")
    axes[1].set(xlabel="Epoch", ylabel="PSNR (dB)",  title="Val PSNR")
    axes[2].set(xlabel="Epoch", ylabel="SSIM",       title="Val SSIM")
    for ax in axes:
        ax.legend(); ax.grid(True, alpha=.3)
    plt.tight_layout()
    plt.savefig(os.path.join(out, "training_curves.png"), dpi=150)
    plt.close()
    print(f"  📊 Saved {os.path.join(out, 'training_curves.png')}")

    summary = {
        "model": "VAEGuidedThermalSRNet",
        "x8":  {"SE-PSNR": round(p8, 2),  "SE-SSIM": round(s8, 4)},
        "x16": {"SE-PSNR": round(p16, 2), "SE-SSIM": round(s16, 4)},
        "architecture": {
            "base": "GuidedThermalSRNet (proven working code)",
            "enhancement": "Pretrained Cross-Modal VAE",
            "phases": ["1: VAE pretrain", "2: SR train (frozen VAE)",
                       "3: End-to-end fine-tune"],
        },
    }
    with open(os.path.join(out, "final_summary.json"), "w") as f:
        json.dump(summary, f, indent=2)
    print(f"  📄 Saved {os.path.join(out, 'final_summary.json')}")


