class VAEGuidedRRDB(nn.Module):
    """
    Working code's GuidedRRDB + VAE latent conditioning.

    Guide features  → gated injection   (from working code, unchanged)
    VAE features    → additive residual  (NEW, gated so it can be ignored)
    """
    def __init__(self, nf=64, gc=32):
        super().__init__()
        self.rrdb = RRDB(nf, gc)

        # Guide injection (IDENTICAL to working code)
        self.guide_proj = nn.Sequential(
            nn.Conv2d(nf, nf, 1), nn.LeakyReLU(0.2, True))
        self.guide_gate = nn.Sequential(
            nn.Conv2d(nf * 2, nf, 1), nn.Sigmoid())

        # ★ VAE injection (NEW — additive with learned gate)
        self.vae_proj = nn.Sequential(
            nn.Conv2d(nf, nf, 1), nn.LeakyReLU(0.2, True))
        self.vae_gate = nn.Sequential(
            nn.Conv2d(nf * 2, nf, 1), nn.Sigmoid())

    def forward(self, x, guide_feat, vae_feat=None):
        out = self.rrdb(x)

        # Guide gating (from working code)
        g    = self.guide_proj(guide_feat)
        gate = self.guide_gate(torch.cat([out, g], 1))
        out  = out * gate + x * (1 - gate)

        # VAE conditioning (NEW — additive residual, can be zero)
        if vae_feat is not None:
            v      = self.vae_proj(vae_feat)
            v_gate = self.vae_gate(torch.cat([out, v], 1))
            out    = out + v * v_gate * 0.1   # small scale factor for stability

        return out


class VAEGuidedTrunk(nn.Module):
    """RRDB trunk with guide + VAE injection at every block."""
    def __init__(self, n_rrdb, nf=64, gc=32):
        super().__init__()
        self.blocks = nn.ModuleList([VAEGuidedRRDB(nf, gc) for _ in range(n_rrdb)])
        self.conv   = nn.Conv2d(nf, nf, 3, 1, 1)

    def forward(self, x, guide_feat, vae_feat=None):
        h = x
        for blk in self.blocks:
            h = blk(h, guide_feat, vae_feat)
        return self.conv(h) + x   # long skip


