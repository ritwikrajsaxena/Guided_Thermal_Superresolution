def train_model(scale, data_root, vae_state=None, head_state=None):
    """
    Phase 2: Train SR with frozen pretrained VAE (epochs 1 → vae_freeze_epochs)
    Phase 3: End-to-end fine-tuning with unfrozen VAE (remaining epochs)
    """
    cfg = CONFIGS[scale]
    out = get_out_dir()
    ckpt_dir = os.path.join(out, "checkpoints")
    os.makedirs(ckpt_dir, exist_ok=True)

    print(f"\n{'#'*70}")
    print(f"#  PHASE 2+3: SR TRAINING  ×{scale}")
    print(f"#  {cfg['n_rrdb']} VAE-GuidedRRDB  |  {cfg['epochs']} epochs")
    print(f"#  VAE frozen: first {cfg['vae_freeze_epochs']} epochs")
    print(f"{'#'*70}")

    # ── Data ──
    train_ds = ThermalGuidedDataset(data_root, scale, "train", cfg["ps"], augment=True)
    val_ds   = ThermalGuidedDataset(data_root, scale, "val",   cfg["ps"], augment=False)
    train_dl = DataLoader(train_ds, cfg["bs"], shuffle=True,
                          num_workers=4, pin_memory=True, drop_last=True)
    val_dl   = DataLoader(val_ds, batch_size=1, shuffle=False,
                          num_workers=2, pin_memory=True)

    # ── Bicubic baseline ──
    bic_psnr, bic_ssim = bicubic_baseline(val_dl, scale, DEVICE)
    print(f"\n  Bicubic baseline:  PSNR={bic_psnr:.2f} dB  SSIM={bic_ssim:.4f}")

    # ── Model ──
    model = VAEGuidedThermalSRNet(
        scale, cfg["nf"], cfg["n_rrdb"], cfg["gc"],
        cfg["n_rcab_stage"], cfg["n_rcab_final"],
        latent_dim=cfg["latent_dim"]
    ).to(DEVICE)

    # Load pretrained components
    if vae_state is not None:
        model.vae.load_state_dict(vae_state)
        print("  ✓ Loaded pretrained VAE weights")
    if head_state is not None:
        model.head.load_state_dict(head_state)
        print("  ✓ Loaded pretrained head weights")

    n_total = sum(p.numel() for p in model.parameters())
    n_train = sum(p.numel() for p in model.parameters() if p.requires_grad)
    print(f"  Parameters: {n_total:,} total  |  {n_train:,} trainable  |  "
          f"{n_total*4/1024**2:.1f} MB\n")

    # ── Loss ──
    criterion = CombinedSRLoss(
        **cfg["loss_w"],
        w_kl=cfg["w_kl"],
        w_vae_recon=cfg["w_vae_recon"]
    ).to(DEVICE)

    # ── Optimizer (differential LR — from working code) ──
    guide_ids = set(id(p) for p in model.guide_enc.parameters())
    vae_ids   = set(id(p) for p in model.vae.parameters())

    main_params  = [p for p in model.parameters()
                    if id(p) not in guide_ids and id(p) not in vae_ids
                    and p.requires_grad]
    guide_params = [p for p in model.guide_enc.parameters() if p.requires_grad]
    vae_params   = [p for p in model.vae.parameters() if p.requires_grad]

    optimizer = optim.AdamW([
        {"params": main_params,  "lr": cfg["lr"]},
        {"params": guide_params, "lr": cfg["lr"] * 0.1},
        {"params": vae_params,   "lr": cfg["lr"] * 0.1},
    ], weight_decay=1e-4)

    # ── Scheduler (from working code: T_0=100) ──
    scheduler = optim.lr_scheduler.CosineAnnealingWarmRestarts(
        optimizer, T_0=100, T_mult=2, eta_min=1e-6)

    ema = EMA(model, decay=0.999)

    # ── Freeze VAE for Phase 2 ──
    vae_frozen = True
    if vae_state is not None:
        for p in model.vae.parameters():
            p.requires_grad = False
        print(f"  ❄ VAE frozen for first {cfg['vae_freeze_epochs']} epochs\n")

    best_ckpt = os.path.join(ckpt_dir, f"best_x{scale}.pth")
    best_psnr, best_ssim = 0.0, 0.0
    history = {"epoch": [], "loss": [], "psnr": [], "ssim": []}

    for epoch in range(1, cfg["epochs"] + 1):
        # ── Phase transition: unfreeze VAE ──
        if vae_frozen and epoch > cfg["vae_freeze_epochs"]:
            for p in model.vae.parameters():
                p.requires_grad = True
            vae_frozen = False
            ema = EMA(model, decay=0.999)
            print(f"\n  🔥 Phase 3: VAE unfrozen at epoch {epoch} "
                  f"→ end-to-end fine-tuning\n")

        model.train()
        ep_loss = 0.0

        for batch in train_dl:
            lr, hr, vis = batch[0], batch[1], batch[2]
            lr, hr, vis = lr.to(DEVICE), hr.to(DEVICE), vis.to(DEVICE)

            pred, kl_loss, vae_recon_loss = model(lr, vis, training=True)

            if pred.shape[2:] != hr.shape[2:]:
                pred = F.interpolate(pred, hr.shape[2:],
                                     mode="bilinear", align_corners=False)

            # KL warmup starts AFTER VAE is unfrozen
            effective_epoch = max(0, epoch - cfg["vae_freeze_epochs"])
            loss = criterion(pred, hr, kl_loss, vae_recon_loss,
                             effective_epoch, cfg["epochs"],
                             cfg["kl_warmup"])

            if math.isnan(loss.item()):
                print("⚠ NaN loss – skipping batch")
                continue

            optimizer.zero_grad(set_to_none=True)
            loss.backward()
            torch.nn.utils.clip_grad_norm_(model.parameters(), 0.5)
            optimizer.step()
            ema.update(model)
            ep_loss += loss.item()

        scheduler.step()
        avg_loss = ep_loss / max(len(train_dl), 1)

        # ── Validate ──
        psnr_val = ssim_val = None
        if epoch % 5 == 0 or epoch <= 3:
            ema.apply(model)
            psnr_val, ssim_val = validate(model, val_dl, DEVICE, use_ensemble=False)
            ema.restore(model)

            improved = ""
            if psnr_val > best_psnr:
                best_psnr = psnr_val
                best_ssim = ssim_val
                ema.apply(model)
                torch.save(model.state_dict(), best_ckpt)
                ema.restore(model)
                improved = " ★"

            cur_lr = optimizer.param_groups[0]["lr"]
            vae_tag = "❄" if vae_frozen else "🔥"
            improvement = psnr_val - bic_psnr
            print(f"  Ep {epoch:4d}/{cfg['epochs']}  loss={avg_loss:.5f}  "
                  f"PSNR={psnr_val:.2f} (+{improvement:.1f})  "
                  f"SSIM={ssim_val:.4f}  best={best_psnr:.2f}/{best_ssim:.4f}  "
                  f"lr={cur_lr:.1e}  VAE={vae_tag}{improved}")

        history["epoch"].append(epoch)
        history["loss"].append(avg_loss)
        history["psnr"].append(psnr_val)
        history["ssim"].append(ssim_val)

    # ── Final self-ensemble evaluation ──
    print(f"\n  Final 8× self-ensemble evaluation …")
    model.load_state_dict(torch.load(best_ckpt))
    model.to(DEVICE)
    final_psnr, final_ssim = validate(model, val_dl, DEVICE, use_ensemble=True)

    print(f"\n{'='*70}")
    print(f"  RESULTS  ×{scale}")
    print(f"{'='*70}")
    print(f"  Bicubic baseline:    PSNR={bic_psnr:.2f}  SSIM={bic_ssim:.4f}")
    print(f"  Best single-pass:    PSNR={best_psnr:.2f}  SSIM={best_ssim:.4f}")
    print(f"  8× self-ensemble:    SE-PSNR={final_psnr:.2f}  SE-SSIM={final_ssim:.4f}")
    print(f"  Improvement over bic: +{max(best_psnr,final_psnr)-bic_psnr:.2f} dB")
    print(f"{'='*70}\n")

    if final_psnr > best_psnr:
        best_psnr = final_psnr
        best_ssim = final_ssim

    return model, history, best_psnr, best_ssim


