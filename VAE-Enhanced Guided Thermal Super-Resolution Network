class VAEGuidedThermalSRNet(nn.Module):
    """
    LR thermal (1ch) + HR visible (3ch) → HR thermal (1ch)

    Architecture (based on working code + VAE):
    ──────────────────────────────────────────────
    1.  Thermal head             → shallow features
    2.  GuideEncoder (ResNet-34) → multi-scale visible features
    3.  ★ CrossModalVAE          → aligned latent features (NEW)
    4.  VAEGuidedTrunk           → deep features (guide + VAE injected at every block)
    5.  SFT pre-fusion           → prepare for upsampling
    6.  Progressive ×2 upsample  → with SFT fusion at each stage
    7.  RCAB refinement          → final quality polish
    8.  Output + bicubic skip    → global residual learning
    """
    def __init__(self, scale, nf=64, n_rrdb=12, gc=32,
                 n_rcab_stage=3, n_rcab_final=4, latent_dim=32):
        super().__init__()
        self.scale = scale

        # ── Thermal head (from working code) ──
        self.head = nn.Sequential(
            nn.Conv2d(1, nf, 3, 1, 1), nn.LeakyReLU(0.2, True),
            nn.Conv2d(nf, nf, 3, 1, 1))

        # ── Guide encoder (from working code) ──
        self.guide_enc = GuideEncoder(nf)

        # ── ★ Cross-Modal VAE (NEW) ──
        self.vae = CrossModalVAE(nf, latent_dim)

        # ── VAE-Enhanced Guided Trunk (modified working code) ──
        self.guided_trunk = VAEGuidedTrunk(n_rrdb, nf, gc)

        # ── Pre-upsample fusion (from working code) ──
        self.pre_fuse = EnhancedSFTFusion(nf)

        # ── Progressive upsample (from working code) ──
        n_stages = int(math.log2(scale))
        self.n_stages = n_stages

        self.up_convs = nn.ModuleList()
        self.fusions  = nn.ModuleList()
        self.refiners = nn.ModuleList()

        self._guide_keys = []
        rem = scale
        for _ in range(n_stages):
            rem //= 2
            if   rem >= 16: self._guide_keys.append("s16")
            elif rem >= 8:  self._guide_keys.append("s8")
            elif rem >= 4:  self._guide_keys.append("s4")
            elif rem >= 2:  self._guide_keys.append("s2")
            else:           self._guide_keys.append("s1")

        for _ in range(n_stages):
            self.up_convs.append(nn.Sequential(
                nn.Conv2d(nf, nf * 4, 3, 1, 1),
                nn.PixelShuffle(2),
                nn.LeakyReLU(0.2, True)))
            self.fusions.append(EnhancedSFTFusion(nf))
            self.refiners.append(nn.Sequential(
                *[RCAB(nf) for _ in range(n_rcab_stage)]))

        # ── Final refinement (from working code) ──
        self.final_ref = nn.Sequential(*[RCAB(nf) for _ in range(n_rcab_final)])
        self.out_conv  = nn.Sequential(
            nn.Conv2d(nf, nf, 3, 1, 1), nn.LeakyReLU(0.2, True),
            nn.Conv2d(nf, 1, 3, 1, 1))

    @property
    def _pre_key(self):
        s = self.scale
        if   s >= 16: return "s16"
        elif s >= 8:  return "s8"
        elif s >= 4:  return "s4"
        else:         return "s2"

    def forward(self, lr_therm, hr_vis, training=True):
        # Bicubic baseline for global residual
        bic = F.interpolate(lr_therm, scale_factor=self.scale,
                            mode="bicubic", align_corners=False)

        # Thermal features
        shallow = self.head(lr_therm)

        # Guide features (multi-scale)
        gf = self.guide_enc(hr_vis)

        # Guide at LR resolution for trunk injection
        g_lr = F.interpolate(gf[self._pre_key], size=shallow.shape[2:],
                             mode="bilinear", align_corners=False)

        # ★ VAE cross-modal alignment
        kl_loss = vae_recon_loss = None
        if training:
            vae_feat, kl_loss, vae_recon_loss = self.vae(shallow, g_lr, training=True)
        else:
            vae_feat = self.vae(shallow, g_lr, training=False)

        # VAE-Enhanced deep trunk
        deep = self.guided_trunk(shallow, g_lr, vae_feat)

        # Pre-upsample fusion
        x = self.pre_fuse(deep, g_lr)

        # Progressive upsample
        for i in range(self.n_stages):
            x = self.up_convs[i](x)
            g = F.interpolate(gf[self._guide_keys[i]], size=x.shape[2:],
                              mode="bilinear", align_corners=False)
            x = self.fusions[i](x, g)
            x = self.refiners[i](x)

        x   = self.final_ref(x)
        out = self.out_conv(x)

        if out.shape[2:] != bic.shape[2:]:
            out = F.interpolate(out, size=bic.shape[2:],
                                mode="bilinear", align_corners=False)

        if training:
            return out + bic, kl_loss, vae_recon_loss
        return out + bic


