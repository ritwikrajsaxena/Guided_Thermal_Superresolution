@torch.no_grad()
def run_test_and_create_submission(data_root):
    out = get_out_dir()
    submission_dir = os.path.join(out, "submission")
    all_metrics = {}

    for scale in [8, 16]:
        cfg = CONFIGS[scale]
        ckpt_path = os.path.join(out, "checkpoints", f"best_x{scale}.pth")

        if not os.path.isfile(ckpt_path):
            print(f"\n  ✗ Checkpoint not found: {ckpt_path}")
            continue

        model = VAEGuidedThermalSRNet(
            scale, cfg["nf"], cfg["n_rrdb"], cfg["gc"],
            cfg["n_rcab_stage"], cfg["n_rcab_final"],
            latent_dim=cfg["latent_dim"]
        ).to(DEVICE)
        model.load_state_dict(torch.load(ckpt_path, map_location=DEVICE))
        model.eval()

        sub_dir = os.path.join(submission_dir, f"x{scale}")
        os.makedirs(sub_dir, exist_ok=True)
        for f in glob.glob(os.path.join(sub_dir, "*")):
            os.remove(f)

        test_ds = ThermalGuidedTestDataset(data_root, scale)
        test_dl = DataLoader(test_ds, batch_size=1, shuffle=False, num_workers=2)

        print(f"\n  ×{scale} test — {len(test_ds)} images")
        for idx, (lr, vis, th_base, vis_filename) in enumerate(test_dl):
            lr, vis = lr.to(DEVICE), vis.to(DEVICE)
            pred = self_ensemble(model, lr, vis).clamp(0, 1)
            sr_uint8 = (pred[0, 0].cpu().numpy() * 255).astype(np.uint8)
            out_name = os.path.splitext(vis_filename[0])[0] + ".bmp"
            Image.fromarray(sr_uint8, mode="L").save(
                os.path.join(sub_dir, out_name), format="BMP")
            if (idx + 1) % 20 == 0 or idx == 0:
                print(f"    {idx+1:3d}/{len(test_ds)}  {th_base[0]} → {out_name}")

        print(f"  ✓ Saved {len(test_ds)} SR images → {sub_dir}/")

        # Validation metrics
        val_ds = ThermalGuidedDataset(data_root, scale, "val", cfg["ps"], augment=False)
        val_dl = DataLoader(val_ds, batch_size=1, shuffle=False, num_workers=2)
        psnr_v, ssim_v = validate(model, val_dl, DEVICE, use_ensemble=True)
        all_metrics[scale] = {"psnr": psnr_v, "ssim": ssim_v}
        print(f"  Val  SE-PSNR={psnr_v:.2f}  SE-SSIM={ssim_v:.4f}")

    # Create zip
    zip_path = os.path.join(out, "submission.zip")
    with zipfile.ZipFile(zip_path, "w", zipfile.ZIP_DEFLATED) as zf:
        for folder in ["x8", "x16"]:
            fp = os.path.join(submission_dir, folder)
            if os.path.isdir(fp):
                for fname in sorted(os.listdir(fp)):
                    zf.write(os.path.join(fp, fname), os.path.join(folder, fname))

    with zipfile.ZipFile(zip_path, "r") as zf:
        contents = zf.namelist()

    print(f"\n{'='*70}")
    print(f"  ✅  SUBMISSION ZIP")
    print(f"{'='*70}")
    print(f"  Path:  {zip_path}")
    print(f"  Size:  {os.path.getsize(zip_path)/1024:.1f} KB  |  {len(contents)} files")
    for s in [8, 16]:
        if s in all_metrics:
            m = all_metrics[s]
            print(f"  ×{s}:  SE-PSNR={m['psnr']:.2f}  SE-SSIM={m['ssim']:.4f}")
    print(f"{'='*70}")

    return zip_path, all_metrics


