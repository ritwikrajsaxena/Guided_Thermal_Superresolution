def pretrain_vae(data_root, scale):
    """
    Phase 1: Pretrain Cross-Modal VAE on feature reconstruction.

    The VAE learns to:
    1. Encode thermal features → compact latent
    2. Encode visible features → same latent space
    3. Reconstruct thermal features from fused latent
    4. Align thermal and visible distributions (alignment loss)

    Returns: pretrained VAE and head state dicts.
    """
    cfg = CONFIGS[scale]
    out = get_out_dir()
    ckpt_dir = os.path.join(out, "checkpoints")
    os.makedirs(ckpt_dir, exist_ok=True)

    epochs    = cfg["vae_pretrain_epochs"]
    beta      = cfg["vae_pretrain_beta"]
    lr_rate   = cfg["vae_pretrain_lr"]
    nf        = cfg["nf"]
    latent_dim = cfg["latent_dim"]

    print(f"\n{'='*70}")
    print(f"  PHASE 1: VAE PRETRAINING  (scale ×{scale})")
    print(f"  β={beta}  latent_dim={latent_dim}  epochs={epochs}")
    print(f"{'='*70}")

    # Dataset (smaller patches for faster VAE pretraining)
    vae_ps = min(cfg["ps"], 128)
    train_ds = ThermalGuidedDataset(data_root, scale, "train", vae_ps, augment=True)
    train_dl = DataLoader(train_ds, batch_size=8, shuffle=True,
                          num_workers=4, pin_memory=True, drop_last=True)

    # Feature extractors
    head = nn.Sequential(
        nn.Conv2d(1, nf, 3, 1, 1), nn.LeakyReLU(0.2, True),
        nn.Conv2d(nf, nf, 3, 1, 1)).to(DEVICE)

    guide_enc = GuideEncoder(nf).to(DEVICE)
    guide_enc.eval()
    for p in guide_enc.parameters():
        p.requires_grad = False

    # VAE
    vae = CrossModalVAE(nf, latent_dim).to(DEVICE)

    n_vae   = sum(p.numel() for p in vae.parameters())
    n_head  = sum(p.numel() for p in head.parameters())
    print(f"  VAE params: {n_vae:,}  |  Head params: {n_head:,}\n")

    optimizer = optim.AdamW(
        list(vae.parameters()) + list(head.parameters()),
        lr=lr_rate, weight_decay=1e-4)
    scheduler = optim.lr_scheduler.CosineAnnealingLR(optimizer, epochs, eta_min=1e-6)

    pre_key = "s16" if scale >= 16 else ("s8" if scale >= 8 else "s4")
    best_loss = float("inf")

    for epoch in range(1, epochs + 1):
        vae.train()
        head.train()
        ep_loss = ep_recon = ep_kl = 0.0

        for lr_t, _, vis, _ in train_dl:
            lr_t, vis = lr_t.to(DEVICE), vis.to(DEVICE)

            th_feat = head(lr_t)
            with torch.no_grad():
                gf = guide_enc(vis)
            g_lr = F.interpolate(gf[pre_key], size=th_feat.shape[2:],
                                 mode="bilinear", align_corners=False)

            latent_feat, kl_loss, recon_loss = vae(th_feat, g_lr, training=True)

            beta_eff = beta * min(1.0, epoch / (0.2 * epochs))
            loss = recon_loss + beta_eff * kl_loss

            if math.isnan(loss.item()):
                continue

            optimizer.zero_grad(set_to_none=True)
            loss.backward()
            torch.nn.utils.clip_grad_norm_(
                list(vae.parameters()) + list(head.parameters()), 1.0)
            optimizer.step()

            ep_loss  += loss.item()
            ep_recon += recon_loss.item()
            ep_kl    += kl_loss.item()

        scheduler.step()
        n_batches = max(len(train_dl), 1)

        if epoch % 10 == 0 or epoch <= 3 or epoch == epochs:
            print(f"  VAE Ep {epoch:3d}/{epochs}  "
                  f"loss={ep_loss/n_batches:.5f}  "
                  f"recon={ep_recon/n_batches:.5f}  "
                  f"kl={ep_kl/n_batches:.3f}  "
                  f"β_eff={beta_eff:.5f}")

        if ep_loss / n_batches < best_loss:
            best_loss = ep_loss / n_batches
            torch.save({"vae": vae.state_dict(), "head": head.state_dict(),
                        "epoch": epoch, "loss": best_loss},
                       os.path.join(ckpt_dir, f"vae_pretrained_x{scale}.pth"))

    print(f"\n  ✓ VAE pretrained  best_loss={best_loss:.5f}")
    print(f"  ✓ Saved → {ckpt_dir}/vae_pretrained_x{scale}.pth\n")

    return vae.state_dict(), head.state_dict()


